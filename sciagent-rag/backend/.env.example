# 环境配置示例

# ============================================
# LLM 统一配置（只需要这三个参数）
# ============================================
# 支持所有兼容 OpenAI API 格式的模型服务
# 例如：OpenAI、OpenRouter、Together.ai、本地部署的模型等

# LLM_BASE_URL=  # API 基础 URL（可选，不填使用默认 OpenAI）
# LLM_MODEL_ID=   # 模型 ID（必填）
# LLM_API_KEY=    # API 密钥（必填）

# ============================================
# 配置示例
# ============================================

# 示例 1：使用 OpenAI 官方
# LLM_BASE_URL=
# LLM_MODEL_ID=gpt-4o
# LLM_API_KEY=sk-xxxxx

# 示例 2：使用 OpenRouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL_ID=openai/gpt-4o
# LLM_API_KEY=sk-or-xxxxx

# 示例 3：使用本地模型（兼容 OpenAI 格式）
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL_ID=llama-3-8b
# LLM_API_KEY=dummy

# ============================================
# 其他配置
# ============================================
APP_NAME=AI 交互科学仿真平台
APP_VERSION=1.0.0

HOST=0.0.0.0
PORT=8000

CHROMA_DB_PATH=./chromadb

TESSERACT_PATH=/usr/local/bin/tesseract
